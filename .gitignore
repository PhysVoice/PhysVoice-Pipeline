# Python venv (setup.sh가 생성)
.venv/
venv/

# Python 캐시
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# 모델/런타임 캐시
outputs/
.cache/
# 시연용 텔레옵 녹화 데이터셋(로컬, 용량 큼)
recordings/
*.onnx
*.onnx.data
*.wav
*.m4a
*.mp3
# 단, 시연용 TTS 멘트(미리 렌더)는 자산이므로 추적한다
!bridge/voice_lines/*.wav

# OS / 에디터
.DS_Store
.idea/
*.swp
